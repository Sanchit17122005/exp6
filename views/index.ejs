<!DOCTYPE html>
<html>
<head>
    <title>Student Management</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<h1>Student Management System</h1>

<div class="top-btn">
    <a href="/new" class="primary-btn">Add Student</a>
</div>

<% students.forEach(s => { %>
<div class="card">
    
    <div class="card-content">
        <h2><%= s.name %></h2>
        <p>Roll: <%= s.roll %></p>
    </div>

    <div class="actions">
        <a href="/<%= s._id %>/edit" class="edit-btn">Edit</a>

        <form action="/<%= s._id %>?_method=DELETE" method="POST">
            <button class="delete-btn">Delete</button>
        </form>
    </div>

</div>
<% }) %>

</body>
</html>